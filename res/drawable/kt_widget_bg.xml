<?xml version="1.0" encoding="utf-8"?>
<!--
    kt_widget_bg.xml – bakgrunn for widget med avrundede hjørner og skygge.
    Plasseres i res/drawable/kt_widget_bg.xml
    Bruker layer-list for gradient + skygge-lag.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Skygge-lag (forskjøvet ned-høyre) -->
    <item
        android:left="2dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#22000000" />
        </shape>
    </item>

    <!-- Gradient-bakgrunn med avrundede hjørner -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#F4F5FA"
                android:endColor="#E8EAF2" />
            <stroke
                android:width="1dp"
                android:color="#CCCED8" />
        </shape>
    </item>

</layer-list>
