<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_bg.xml – bakgrunn for widget.
    Hvit med subtil avrundet kant og lett skygge.
    Bruker shape drawable som fungerer i RemoteViews.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#F4F5FA" />
    <corners android:radius="16dp" />
    <stroke
        android:width="1dp"
        android:color="#DDE0EE" />
</shape>
