<?xml version="1.0" encoding="utf-8"?>
<!--
    kt_widget.xml – layout for Kommunikasjonstavle hjemskjerm-widget.

    RemoteViews støtter kun et begrenset sett widgets:
    TextView, ImageView, Button, ProgressBar, LinearLayout, FrameLayout,
    RelativeLayout, GridLayout (Android 12+).

    Størrelse: 3×1 celler (ca 250×110dp på de fleste skjermer).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <!-- Topprad: app-tittel + fargeprikk for status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_app_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Kommunikasjonstavle"
            android:textSize="11sp"
            android:textColor="#666688"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Statusprikk: grønn=aktiv, oransje=kommende, grå=ferdig -->
        <View
            android:id="@+id/widget_status_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#CCCCCC" />

    </LinearLayout>

    <!-- Mellomlinje -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#22000000"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="6dp" />

    <!-- Aktivitetsnavn-label (Nå: / Neste: / Ferdig) -->
    <TextView
        android:id="@+id/widget_activity_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Neste:"
        android:textSize="12sp"
        android:textColor="#4D96FF"
        android:textStyle="bold" />

    <!-- Aktivitetsnavn -->
    <TextView
        android:id="@+id/widget_activity_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="17sp"
        android:textColor="#12183A"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="2dp" />

    <!-- Klokkeslett -->
    <TextView
        android:id="@+id/widget_activity_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#667788"
        android:layout_marginTop="2dp" />

</LinearLayout>
