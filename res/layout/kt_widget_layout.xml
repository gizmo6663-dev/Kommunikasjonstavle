<?xml version="1.0" encoding="utf-8"?>
<!--
    kt_widget_layout.xml – Kommunikasjonstavle Widget
    Modernisert: solid bakgrunn inlinet direkte (ingen ekstern drawable).
    kt_line1 økt til 16sp.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F5FA"
    android:padding="2dp">

    <!-- Bilde fyller tilgjengelig plass -->
    <ImageView
        android:id="@+id/kt_img"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:padding="6dp"
        android:visibility="gone" />

    <!-- Tekstboks + oppdater-knapp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E8EAF2"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Primær aktivitetslinje – økt til 16sp -->
            <TextView
                android:id="@+id/kt_line1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#12183A"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Sekundær linje (tid / neste) -->
            <TextView
                android:id="@+id/kt_line2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#445566"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Oppdater-knapp – ↻ (U+21BB) -->
        <TextView
            android:id="@+id/kt_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#8635;"
            android:textSize="22sp"
            android:textColor="#4D96FF"
            android:paddingStart="10dp"
            android:paddingEnd="4dp" />

    </LinearLayout>

</LinearLayout>
