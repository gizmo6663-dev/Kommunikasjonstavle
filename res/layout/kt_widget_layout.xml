<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F5FA">

    <!-- Bilde fyller tilgjengelig plass, centerCrop for å fylle flaten -->
    <ImageView
        android:id="@+id/kt_img"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:padding="8dp"
        android:visibility="gone" />

    <!-- Tekstboks + oppdater-knapp nederst -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E8EAF2"
        android:paddingStart="10dp"
        android:paddingEnd="6dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/kt_line1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#12183A"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/kt_line2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#445566"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Oppdater-knapp -->
        <TextView
            android:id="@+id/kt_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↻"
            android:textSize="20sp"
            android:textColor="#4D96FF"
            android:paddingStart="8dp"
            android:paddingEnd="4dp" />

    </LinearLayout>

</LinearLayout>
