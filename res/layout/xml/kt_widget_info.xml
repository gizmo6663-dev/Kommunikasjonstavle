<?xml version="1.0" encoding="utf-8"?>
<!--
    kt_widget_info.xml – metadata for AppWidgetProvider.

    minWidth/minHeight er i dp. Android beregner antall celler slik:
    celler = floor((bredde + 30) / 70)
    3×1 celler = minWidth 180dp, minHeight 40dp
    4×2 celler = minWidth 250dp, minHeight 110dp
-->
<appwidget-provider
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="180dp"
    android:minHeight="110dp"
    android:minResizeWidth="120dp"
    android:minResizeHeight="80dp"
    android:targetCellWidth="3"
    android:targetCellHeight="2"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/kt_widget"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/app_name" />
